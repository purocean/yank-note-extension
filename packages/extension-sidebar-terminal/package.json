{
  "name": "@yank-note/extension-sidebar-terminal",
  "version": "1.0.0",
  "displayName": "Sidebar Terminal",
  "description": "Run shell commands in a dedicated sidebar terminal",
  "displayName_ZH-CN": "侧栏终端",
  "description_ZH-CN": "在独立侧栏终端中运行 Shell 命令",
  "keywords": [
    "terminal",
    "shell",
    "command",
    "sidebar"
  ],
  "author": "Yank Note",
  "license": "AGPL-3.0",
  "homepage": "https://github.com/purocean/yank-note-extension/tree/main/packages/extension-sidebar-terminal",
  "repository": {
    "type": "git",
    "url": "https://github.com/purocean/yank-note-extension.git"
  },
  "main": "./dist/index.js",
  "style": "./dist/style.css",
  "icon": "./icon.svg",
  "engines": {
    "node": ">=18.20.2",
    "yank-note": "^3.87.0"
  },
  "requirements": {
    "terminal": true
  },
  "files": [
    "*.md",
    "dist",
    "icon.svg"
  ],
  "scripts": {
    "link-extension": "link-yn-extension",
    "unlink-extension": "link-yn-extension --unlink",
    "dev": "vite build --watch --minify=false",
    "build": "vue-tsc --noEmit && vite build",
    "lint": "vue-tsc --noEmit && yarn run eslint '{src,__tests__}/**/*.{js,ts,tsx,vue}'",
    "prepublish": "npm run build"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^13.2.1",
    "@rollup/plugin-replace": "^4.0.0",
    "@vitejs/plugin-vue": "^3.2.0",
    "@vue/eslint-config-standard": "^6.1.0",
    "@vue/eslint-config-typescript": "^10.0.0",
    "@yank-note/runtime-api": "workspace:*",
    "eslint": "^7.32.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.0.0",
    "eslint-plugin-vue": "^8.7.1",
    "sass": "^1.56.1",
    "typescript": "^5.7.2",
    "vite": "^3.2.3",
    "vue": "^3.2.33",
    "vue-tsc": "^0.34.11"
  }
}
