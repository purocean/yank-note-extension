{
  "name": "@yank-note/extension-review",
  "version": "1.0.2",
  "displayName": "Review Comments",
  "displayName_ZH-CN": "审阅批注",
  "description": "Select rendered text, leave review comments, and keep the review data readable in Markdown.",
  "description_ZH-CN": "在预览中选择文字并添加批注，以人和 AI 都易读的 Markdown 形式保存。",
  "keywords": [
    "review",
    "comment",
    "annotation",
    "ai"
  ],
  "author": "Yank Note",
  "license": "AGPL-3.0",
  "homepage": "https://github.com/purocean/yank-note-extension/tree/main/packages/extension-review",
  "repository": {
    "type": "git",
    "url": "https://github.com/purocean/yank-note-extension.git"
  },
  "main": "./dist/index.js",
  "icon": "./icon.svg",
  "engines": {
    "node": ">=18.20.2",
    "yank-note": ">=3.92.0"
  },
  "requirements": {
    "premium": true
  },
  "files": [
    "*.md",
    "dist",
    "types",
    "icon.svg"
  ],
  "scripts": {
    "link-extension": "link-yn-extension",
    "unlink-extension": "link-yn-extension --unlink",
    "dev": "vite build --watch",
    "build": "vue-tsc --noEmit && vite build",
    "test": "tsx --test __tests__/**/*.test.ts",
    "lint": "vue-tsc --noEmit && yarn run eslint '{src,__tests__}/**/*.{js,ts,tsx,vue}'",
    "version": "conventional-changelog -t extension-review- --commit-path . -p angular -i CHANGELOG.md -s && npm run tag-version",
    "tag-version": "git add . && git commit -m 'chore(release): bump extension-review version' && git tag extension-review-$npm_package_version",
    "prepublish": "npm run build"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^13.2.1",
    "@rollup/plugin-replace": "^4.0.0",
    "@vitejs/plugin-vue": "^3.2.0",
    "@vue/eslint-config-standard": "^6.1.0",
    "@vue/eslint-config-typescript": "^10.0.0",
    "@yank-note/runtime-api": "workspace:*",
    "@types/jsdom": "^21.1.7",
    "conventional-changelog-cli": "^2.2.2",
    "eslint": "^7.32.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.0",
    "eslint-plugin-vue": "^8.7.1",
    "jsdom": "^22.1.0",
    "rollup-plugin-terser": "^7.0.2",
    "typescript": "^4.6.4",
    "tsx": "^4.19.4",
    "vite": "^3.2.3",
    "vue": "^3.2.33",
    "vue-tsc": "^0.34.11"
  }
}
