{
  "name": "@yank-note/extension-change-gutter",
  "version": "1.0.1",
  "displayName": "Change Gutter",
  "displayName_ZH-CN": "编辑装订线",
  "description": "Show added, modified, and deleted lines in the Monaco editor gutter.",
  "description_ZH-CN": "在 Monaco 编辑器装订线中显示新增、修改和删除的行。",
  "keywords": [
    "editor",
    "git",
    "gutter",
    "diff"
  ],
  "author": "Yank Note",
  "license": "AGPL-3.0",
  "homepage": "https://github.com/purocean/yank-note-extension/tree/main/packages/extension-change-gutter",
  "repository": {
    "type": "git",
    "url": "https://github.com/purocean/yank-note-extension.git"
  },
  "main": "./dist/index.js",
  "icon": "./icon.svg",
  "engines": {
    "node": ">=18.20.2",
    "yank-note": ">=3.92.0"
  },
  "files": [
    "*.md",
    "dist",
    "server",
    "types",
    "icon.svg"
  ],
  "scripts": {
    "link-extension": "link-yn-extension",
    "unlink-extension": "link-yn-extension --unlink",
    "dev": "vite build --watch",
    "build": "vue-tsc --noEmit && vite build",
    "test": "tsx --test __tests__/**/*.test.ts",
    "lint": "vue-tsc --noEmit && yarn run eslint '{src,server,__tests__}/**/*.{js,cjs,ts,tsx,vue}'",
    "version": "conventional-changelog -t extension-change-gutter- --commit-path . -p angular -i CHANGELOG.md -s && npm run tag-version",
    "tag-version": "git add . && git commit -m 'chore(release): bump extension-change-gutter version' && git tag extension-change-gutter-$npm_package_version",
    "prepublish": "npm run build"
  },
  "dependencies": {
    "vscode-diff": "^3.0.1"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^13.2.1",
    "@rollup/plugin-replace": "^4.0.0",
    "@vitejs/plugin-vue": "^3.2.0",
    "@vue/eslint-config-standard": "^6.1.0",
    "@vue/eslint-config-typescript": "^10.0.0",
    "@yank-note/runtime-api": "workspace:*",
    "conventional-changelog-cli": "^2.2.2",
    "eslint": "^7.32.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.0",
    "eslint-plugin-vue": "^8.7.1",
    "rollup-plugin-terser": "^7.0.2",
    "tsx": "^4.19.4",
    "typescript": "^4.6.4",
    "vite": "^3.2.3",
    "vue": "^3.2.33",
    "vue-tsc": "^0.34.11"
  }
}
